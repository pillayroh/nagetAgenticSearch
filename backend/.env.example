# Copy to `.env` in this folder. Run uvicorn from `backend/`.

# Default: no Mongo (matches simple deploys / how most hosted demos run).
USE_MONGODB=false
# Set USE_MONGODB=true and a URI when you want persistent runs + cross-request URL cache.
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=agentic_search

# Search: Tavily only (required for real web results; otherwise mock)
TAVILY_API_KEY=
# Optional: general | news | finance
TAVILY_TOPIC=
MOCK_SEARCH=false

SNIPPET_FIRST=true
SNIPPET_FIRST_MIN_CHARS=280
ALWAYS_FETCH_TOP_N=5

# LLM: Hugging Face Inference (routed provider)
LLM_BACKEND=huggingface
HF_INFERENCE_PROVIDER=featherless-ai
# https://huggingface.co/settings/tokens — enable "Make calls to Inference Providers"
HF_TOKEN=
LLM_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# Alternative: OpenAI-compatible (e.g. Ollama: LLM_BASE_URL=http://127.0.0.1:11434/v1)
# LLM_BACKEND=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=

LLM_JSON_OBJECT=true
LLM_MAX_TOKENS=4096
LLM_MAX_EVIDENCE_CHARS=28000
LLM_MAX_ENTITIES=8

SEARCH_MAX_RESULTS=15
SEARCH_CHUNK_CHARS=3000
SEARCH_MAX_CHUNKS_PER_URL=2

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Allows all https://*.vercel.app; set to empty to turn off.
# CORS_ORIGIN_REGEX=
